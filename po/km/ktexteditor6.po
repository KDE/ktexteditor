#. i18n: ectx: property (text), widget (QLabel, label)
#: dialogs/indentationconfigwidget.ui:225
#, fuzzy, kde-format
#| msgid ""
#| "<html><head><meta name=\"qrichtext\" content=\"1\" /><style type=\"text/"
#| "css\">\n"
#| "p, li { white-space: pre-wrap; }\n"
#| "</style></head><body>\n"
#| "<p>Tab key action (if no selection exists) <a href=\"If you want <b>Tab</"
#| "b> to align the current line in the current code block like in emacs, "
#| "make <b>Tab</b> a shortcut to the action <b>Align</b>.\"><span>More ...</"
#| "span></a></p></body></html>"
msgid ""
"<html><head><meta name=\"qrichtext\" content=\"1\" /><style type=\"text/css"
"\">\n"
"p, li { white-space: pre-wrap; }\n"
"</style></head><body>\n"
"<p>Tab key action (if no selection exists) <a href=\"If you want <b>Tab</b> "
"to align the current line in the current code block like in Emacs, make "
"<b>Tab</b> a shortcut to the action <b>Format Indentation</b>."
"\"><span>More ...</span></a></p></body></html>"
msgstr ""
"<html><head><meta name=\"qrichtext\" content=\"1\" /><style type=\"text/css"
"\">\n"
"p, li { white-space: pre-wrap; }\n"
"</style></head><body>\n"
"<p>бһҹбһҖбһҳбҹ’бһҳбһ—бһ¶бһ–вҖӢбһӮбҹ’бһҡбһ¶бһ”бҹӢбһ…бһ»бһ…вҖӢбһҗбҹҒбһ”(Tab) (бһ”бҹ’бһҡбһҹбһ·бһ“вҖӢбһ”бһҫвҖӢбһҳбһ·бһ“вҖӢбһҳбһ¶бһ“вҖӢбһҮбһҳбҹ’бһҡбһҫбһҹ) <a href=\"If you want "
"<b>бһҗбҹҒбһ”(Tab)</b> бһҠбһҫбһҳбҹ’бһ”бһёвҖӢбһҸбһҳбҹ’бһҡбһ№бһҳвҖӢбһ”бһ“бҹ’бһ‘бһ¶бһҸбҹӢвҖӢбһ”бһ…бҹ’бһ…бһ»бһ”бҹ’бһ”бһ“бҹ’бһ“вҖӢбһ“бҹ…вҖӢбһҖбҹ’бһ“бһ»бһ„вҖӢбһ”бҹ’бһӣбһ»бһҖвҖӢбһҖбһјбһҠвҖӢвҖӢбһ”бһ…бҹ’бһ…бһ»бһ”бҹ’бһ”бһ“бҹ’бһ“вҖӢбһҠбһјбһ…вҖӢбһ“бҹ…вҖӢбһҖбҹ’бһ“бһ»бһ„ emacs, make "
"бһ•бҹ’бһӣбһјбһңбһҖбһ¶бһҸбҹӢвҖӢ<b>бһҗбҹҒбһ”(Tab)</b> бһ‘бҹ…вҖӢвҖӢбһҹбһҖбһҳбҹ’бһҳбһ—бһ¶бһ– <b>бһҸбһҳбҹ’бһҡбһ№бһҳ</b>В бҹ”\"><span>бһ…бҹ’бһҡбһҫбһ“вҖӢбһ‘бҹҖбһҸ ...</span></"
"a></p></body></html>"

#. i18n: ectx: property (whatsThis), widget (QRadioButton, rbTabAdvances)
#: dialogs/indentationconfigwidget.ui:276
#, kde-format
msgid ""
"If this option is selected, the <b>Tab</b> key always inserts white space so "
"that the next tab position is reached. If the option <b>Insert spaces "
"instead of tabulators</b> in the section <b>Editing</b> is enabled, spaces "
"are inserted; otherwise, a single tabulator is inserted."
msgstr ""
"бһ”бҹ’бһҡбһҹбһ·бһ“вҖӢбһ”бһҫвҖӢбһ”бһ¶бһ“вҖӢбһҮбҹ’бһҡбһҫбһҹ бһӮбҹ’бһҡбһ¶бһ”бҹӢбһ…бһ»бһ… <b>бһҗбҹҒбһ”</b> бһҸбҹӮбһ„бһҸбҹӮвҖӢбһ”бһүбҹ’бһ…бһјбһӣвҖӢбһ…бһ“бҹ’бһӣбҹ„бҹҮвҖӢбһҳбһ·бһ“бһғбһҫбһү бһҠбһјбһ…бҹ’бһ“бҹҒбҹҮвҖӢбһӮбһәвҖӢбһўбһ¶бһ…вҖӢбһ…бһјбһӣвҖӢбһ‘бҹ…вҖӢбһҠбһӣбҹӢвҖӢбһ‘бһёбһҸбһ¶бҹҶбһ„вҖӢбһҗбҹҒбһ”вҖӢ"
"бһ”бһ“бҹ’бһ‘бһ¶бһ”бҹӢВ бҹ” бһ”бҹ’бһҡбһҹбһ·бһ“вҖӢбһ”бһҫвҖӢбһ”бһ¶бһ“вҖӢбһ”бһҫбһҖвҖӢбһҮбһҳбҹ’бһҡбһҫбһҹ <b>бһ”бһүбҹ’бһ…бһјбһӣвҖӢбһ…бһ“бҹ’бһӣбҹ„бҹҮвҖӢбһҮбҹҶбһ“бһҪбһҹвҖӢбһҗбҹҒбһ”</b> бһҖбҹ’бһ“бһ»бһ„вҖӢбһ•бҹ’бһ“бҹӮбһҖ <b>бһҖбҹӮбһҹбһҳбҹ’бһҡбһҪбһӣ</b> бһ“бҹ„бҹҮвҖӢ"
"бһ…бһ“бҹ’бһӣбҹ„бҹҮвҖӢбһӮбһәвҖӢбһҸбҹ’бһҡбһјбһңвҖӢбһ”бһ¶бһ“вҖӢбһ”бһүбҹ’бһ…бһјбһӣ бһ”бһҫвҖӢбһҳбһ·бһ“бһҠбһјбһ…бҹ’бһ“бҹ„бҹҮвҖӢбһ‘бҹҒ бһҗбҹҒбһ”вҖӢбһҸбҹӮвҖӢбһҳбһҪбһҷвҖӢбһ“бһ№бһ„вҖӢбһҸбҹ’бһҡбһјбһңвҖӢбһ”бһ¶бһ“вҖӢбһ”бһүбҹ’бһ…бһјбһӣВ бҹ”"

