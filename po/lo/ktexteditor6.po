#. i18n: ectx: property (text), widget (QLabel, label_3)
#: dialogs/completionconfigtab.ui:165
#, kde-format
msgid ""
"Show documentation beside completion box. If disabled, documentation can be "
"shown by pressing Alt key."
msgstr ""
"ສະແດງເອກະສານປະກອບຂ້າງກ່ອງເຕີມຄຳ. ຖ້າປິດໃຊ້ງານ, ສາມາດສະແດງເອກະສານໄດ້ໂດຍການກົດປຸ່ມ Alt."

#. i18n: ectx: property (text), widget (QLabel, label)
#: dialogs/editconfigwidget.ui:22
#, kde-format
msgid "Word wrap:"
msgstr "ຕັດແຖວຄຳ:"

#. i18n: ectx: property (whatsThis), widget (QCheckBox, chkStaticWordWrap)
#: dialogs/editconfigwidget.ui:29
#, kde-format
msgid ""
"<p>Automatically start a new line of text when the current line exceeds the "
"length specified by the <b>Wrap words at:</b> option.</p><p>This option does "
"not wrap existing lines of text - use the <b>Apply Static Word Wrap</b> "
"option in the <b>Tools</b> menu for that purpose.</p><p>If you want lines to "
"be <i>visually wrapped</i> instead, according to the width of the view, "
"enable <b>Dynamic Word Wrap</b> in the <b>Appearance</b> config page.</p>"
msgstr ""
"<p>ເລີ່ມແຖວໃໝ່ອັດຕະໂນມັດເມື່ອແຖວປັດຈຸບັນເກີນຄວາມຍາວທີ່ກຳນົດໂດຍຕົວເລືອກ <b>ຕັດແຖວຄຳຢູ່ທີ່:</b>.</"
"p><p>ຕົວເລືອກນີ້ຈະບໍ່ຕັດແຖວທີ່ມີຢູ່ແລ້ວ - ໃຫ້ໃຊ້ຕົວເລືອກ <b>ໃຊ້ການຕັດແຖວຄຳແບບຄົງທີ່</b> ໃນເມນູ "
"<b>ເຄື່ອງມື</b> ສຳລັບຈຸດປະສົງນັ້ນ.</p><p>ຖ້າທ່ານຕ້ອງການໃຫ້ແຖວຖືກ <i>ຕັດພຽງແຕ່ການສະແດງຜົນ</i> "
"ແທນ, ຕາມຄວາມກວ້າງຂອງມຸມມອງ, ໃຫ້ເປີດໃຊ້ <b>ການຕັດແຖວແບບໄດນາມິກ</b> ໃນໜ້າຕັ້ງຄ່າ "
"<b>ຮູບລັກສະນະ</b>.</p>"

#. i18n: ectx: property (text), widget (QCheckBox, chkStaticWordWrap)
#: dialogs/editconfigwidget.ui:32
#, kde-format
msgid "Wrap &words at a fixed column"
msgstr "ຕັດ&ແຖວທີ່ຖັນທີ່ກຳນົດໄວ້"

#. i18n: ectx: property (whatsThis), widget (QCheckBox, chkShowStaticWordWrapMarker)
#: dialogs/editconfigwidget.ui:39
#, kde-format
msgid ""
"<p>If this option is checked, a vertical line will be drawn at the word wrap "
"column as defined in the <strong>Editing</strong> properties.</p>"
msgstr ""
"<p>ຖ້າເລືອກຕົວເລືອກນີ້, ເສັ້ນຕັ້ງຈະຖືກແຕ້ມຢູ່ທີ່ຖັນຕັດແຖວຄຳຕາມທີ່ກຳນົດໃນຄຸນສົມບັດ <strong>ການແກ້ໄຂ</"
"strong>.</p>"

#. i18n: ectx: property (text), widget (QCheckBox, chkShowStaticWordWrapMarker)
#: dialogs/editconfigwidget.ui:42
#, kde-format
msgid "&Draw vertical line at the word wrap column"
msgstr "&ຂີດເສັ້ນຕັ້ງຢູ່ບ່ອນຕັດແຖວ"

#. i18n: ectx: property (text), widget (QLabel, lblWordWrap)
#: dialogs/editconfigwidget.ui:49
#, kde-format
msgid "Wra&p words at:"
msgstr "ຕັດ&ແຖວຄຳຢູ່ທີ່:"

#. i18n: ectx: property (whatsThis), widget (QSpinBox, sbWordWrap)
#: dialogs/editconfigwidget.ui:59
#, kde-format
msgid ""
"If the Word Wrap option is selected this entry determines the length (in "
