msgstr "ບັນທຶກເອກະສານປັດຈຸບັນ"

#: view/kateview.cpp:484
#, kde-format
msgid "Revert the most recent editing actions"
msgstr "ຍ້ອນກັບການແກ້ໄຂຫຼ້າສຸດ"

#: view/kateview.cpp:487
#, kde-format
msgid "Revert the most recent undo operation"
msgstr "ຍ້ອນກັບການຍົກເລີກຫຼ້າສຸດ"

#: view/kateview.cpp:491
#, kde-format
msgid "&Scripts"
msgstr "&ສະຄຣິບ"

#: view/kateview.cpp:495
#, kde-format
msgid "Apply &Word Wrap"
msgstr "ນຳໃຊ້ການ&ຕັດຄຳ"

#: view/kateview.cpp:497
#, kde-format
msgid ""
"Use this to wrap the current line, or to reformat the selected lines as "
"paragraph, to fit the 'Wrap words at' setting in the configuration dialog."
"<br /><br />This is a static word wrap, meaning the document is changed."
msgstr ""
"ໃຊ້ອັນນີ້ເພື່ອຕັດຄຳໃນແຖວປັດຈຸບັນ, ຫຼື ຈັດຮູບແບບແຖວທີ່ເລືອກໃໝ່ເປັນຫຍໍ້ໜ້າ, ເພື່ອໃຫ້ພໍດີກັບການຕັ້ງຄ່າ 'ຕັດຄຳທີ່' "
"ໃນກ່ອງໂຕ້ຕອບການຕັ້ງຄ່າ.<br /><br />ນີ້ແມ່ນການຕັດຄຳແບບຄົງທີ່, ໝາຍຄວາມວ່າເອກະສານຈະຖືກປ່ຽນແປງ."

#: view/kateview.cpp:503
#, kde-format
msgid "&Clean Indentation"
msgstr "&ລ້າງການຫຍໍ້ໜ້າ"

#: view/kateview.cpp:505
#, kde-format
msgid ""
"Use this to clean the indentation of a selected block of text (only tabs/"
"only spaces).<br /><br />You can configure whether tabs should be honored "
"and used or replaced with spaces, in the configuration dialog."
msgstr ""
"ໃຊ້ອັນນີ້ເພື່ອລ້າງການຫຍໍ້ໜ້າຂອງບລັອກຂໍ້ຄວາມທີ່ເລືອກ (ສະເພາະແຖບ/ສະເພາະຍະຫວ່າງ).<br /><br /"
">ທ່ານສາມາດຕັ້ງຄ່າວ່າຈະໃຫ້ໃຊ້ແຖບ ຫຼື ແທນທີ່ດ້ວຍຍະຫວ່າງ ໄດ້ໃນກ່ອງໂຕ້ຕອບການຕັ້ງຄ່າ."

#: view/kateview.cpp:510
#, kde-format
msgid "Convert Indentation to Spaces"
msgstr "ແປງການຫຍໍ້ໜ້າເປັນຍະຫວ່າງ"

#: view/kateview.cpp:517
#, kde-format
msgid "Convert Indentation to Tabs"
msgstr "ແປງການຫຍໍ້ໜ້າເປັນແຖບ (Tabs)"

#: view/kateview.cpp:532
#, kde-format
msgid "&Format Indentation"
msgstr "&ຈັດຮູບແບບການຫຍໍ້ໜ້າ"

#: view/kateview.cpp:533
#, kde-format
msgid ""
"Use this to auto indent the current line or block of text to its proper "
"indent level."
msgstr "ໃຊ້ອັນນີ້ເພື່ອຫຍໍ້ໜ້າແຖວປັດຈຸບັນ ຫຼື ບລັອກຂໍ້ຄວາມ ໄປຍັງລະດັບການຫຍໍ້ໜ້າທີ່ເໝາະສົມໂດຍອັດຕະໂນມັດ."

#: view/kateview.cpp:537
#, kde-format
msgctxt "@action"
msgid "&Align On…"
msgstr "&ຈັດລຽງຢູ່ທີ່…"

#: view/kateview.cpp:539
#, kde-format
msgid ""
"This command aligns lines in the selected block or whole document on the "
"column given by a regular expression that you will be prompted for.<br /"
"><br />If you give an empty pattern it will align on the first non-blank "
"character by default.<br />If the pattern has a capture it will indent on "
"the captured match.<br /><br /><i>Examples</i>:<br />With '-' it will insert "
"spaces before the first '-' of each lines to align them all on the same "
"column.<br />With ':\\s+(.)' it will insert spaces before the first non-"
"blank character that occurs after a colon to align them all on the same "
"column."
msgstr ""
"ຄຳສັ່ງນີ້ຈັດລຽງແຖວໃນບລັອກທີ່ເລືອກ ຫຼື ທັງໝົດເອກະສານ ຢູ່ຖັນທີ່ກຳນົດໂດຍນິພົດປົກກະຕິ (regular "
"expression) ທີ່ທ່ານຈະຕ້ອງລະບຸ.<br /><br />ຖ້າທ່ານລະບຸຮູບແບບເປົ່າ "
"ມັນຈະຈັດລຽງຢູ່ທີ່ຕົວອັກສອນທຳອິດທີ່ບໍ່ແມ່ນຍະຫວ່າງໂດຍເລີ່ມຕົ້ນ.<br />ຖ້າຮູບແບບມີການ capture "
"ມັນຈະຫຍໍ້ໜ້າຢູ່ທີ່ບ່ອນທີ່ capture ໄດ້.<br /><br /><i>ຕົວຢ່າງ</i>:<br />ດ້ວຍ '-' "
"ມັນຈະແຊກຍະຫວ່າງກ່ອນ '-' ທຳອິດຂອງແຕ່ລະແຖວ ເພື່ອຈັດລຽງພວກມັນທັງໝົດຢູ່ໃນຖັນດຽວກັນ.<br />ດ້ວຍ ':"
"\\s+(.)' ມັນຈະແຊກຍະຫວ່າງກ່ອນຕົວອັກສອນທຳອິດທີ່ບໍ່ແມ່ນຍະຫວ່າງ ທີ່ເກີດຂຶ້ນຫຼັງຈາກຈຸດສອງເມັດ "
"ເພື່ອຈັດລຽງພວກມັນທັງໝົດຢູ່ໃນຖັນດຽວກັນ."

#: view/kateview.cpp:550
#, kde-format
msgid "C&omment"
msgstr "ໝາຍເຫ&ດ"

#: view/kateview.cpp:553
#, kde-format
msgid ""
"This command comments out the current line or a selected block of text.<br /"
"><br />The characters for single/multiple line comments are defined within "
"the language's highlighting."
msgstr ""
"ຄຳສັ່ງນີ້ເຮັດໝາຍເຫດແຖວປັດຈຸບັນ ຫຼື ບລັອກຂໍ້ຄວາມທີ່ເລືອກ.<br /><br />ຕົວອັກສອນສຳລັບໝາຍເຫດແຖວດຽວ/"
"ຫຼາຍແຖວ ແມ່ນຖືກກຳນົດພາຍໃນການເນັ້ນສີຂອງພາສານັ້ນໆ."

#: view/kateview.cpp:558
#, kde-format
msgid "Go to Previous Editing Location"
msgstr "ໄປຍັງຕຳແໜ່ງການແກ້ໄຂກ່ອນໜ້າ"

#: view/kateview.cpp:564
#, kde-format
msgid "Go to Next Editing Location"
msgstr "ໄປຍັງຕຳແໜ່ງການແກ້ໄຂຖັດໄປ"

#: view/kateview.cpp:570
#, kde-format
msgid "Unco&mment"
msgstr "ຍົກເລີກ&ໝາຍເຫດ"

#: view/kateview.cpp:573
#, kde-format
msgid ""
"This command removes comments from the current line or a selected block of "
"text.<br /><br />The characters for single/multiple line comments are "
"defined within the language's highlighting."
msgstr ""
"ຄຳສັ່ງນີ້ເອົາໝາຍເຫດອອກຈາກແຖວປັດຈຸບັນ ຫຼື ບລັອກຂໍ້ຄວາມທີ່ເລືອກ.<br /><br /"
">ຕົວອັກສອນສຳລັບໝາຍເຫດແຖວດຽວ/ຫຼາຍແຖວ ແມ່ນຖືກກຳນົດພາຍໃນການເນັ້ນສີຂອງພາສານັ້ນໆ."

#: view/kateview.cpp:578
#, kde-format
msgid "Toggle Comment"
msgstr "ເປີດ/ປິດໝາຍເຫດ"

#: view/kateview.cpp:582
#, kde-format
msgid "&Read Only Mode"
msgstr "&ໂໝດອ່ານຢ່າງດຽວ"

#: view/kateview.cpp:583
#, kde-format
msgid "Lock/unlock the document for writing"
msgstr "ລັອກ/ປົດລັອກເອກະສານສຳລັບການຂຽນ"

#: view/kateview.cpp:588
#, kde-format
msgid "&Force RTL Direction"
msgstr "&ບັງຄັບທິດທາງ RTL"

#: view/kateview.cpp:589
#, kde-format
msgid "Force RTL Text Direction"
msgstr "ບັງຄັບທິດທາງຂໍ້ຄວາມ RTL (ຂວາຫາຊ້າຍ)"

#: view/kateview.cpp:599
#, kde-format
msgid "Uppercase"
msgstr "ຕົວພິມໃຫຍ່"

#: view/kateview.cpp:602
#, kde-format
msgid ""
"Convert the selection to uppercase, or the character to the right of the "
"cursor if no text is selected."
msgstr "ແປງສ່ວນທີ່ເລືອກເປັນຕົວພິມໃຫຍ່, ຫຼື ຕົວອັກສອນທາງຂວາຂອງເຄີເຊີ ຖ້າບໍ່ມີຂໍ້ຄວາມຖືກເລືອກ."

#: view/kateview.cpp:608
#, kde-format
msgid "Lowercase"
msgstr "ຕົວພິມນ້ອຍ"

#: view/kateview.cpp:611
#, kde-format
msgid ""
"Convert the selection to lowercase, or the character to the right of the "
"cursor if no text is selected."
msgstr "ແປງສ່ວນທີ່ເລືອກເປັນຕົວພິມນ້ອຍ, ຫຼື ຕົວອັກສອນທາງຂວາຂອງເຄີເຊີ ຖ້າບໍ່ມີຂໍ້ຄວາມຖືກເລືອກ."

#: view/kateview.cpp:617
#, kde-format
msgid "Capitalize"
msgstr "ຂຶ້ນຕົ້ນດ້ວຍຕົວພິມໃຫຍ່"

#: view/kateview.cpp:620
#, kde-format
msgid ""
"Capitalize the selection, or the word under the cursor if no text is "
"selected."
msgstr "ເຮັດໃຫ້ສ່ວນທີ່ເລືອກຂຶ້ນຕົ້ນດ້ວຍຕົວພິມໃຫຍ່, ຫຼື ຄຳທີ່ຢູ່ກ້ອງເຄີເຊີ ຖ້າບໍ່ມີຂໍ້ຄວາມຖືກເລືອກ."

#: view/kateview.cpp:625
#, kde-format
msgid "Join Lines"
msgstr "ຮວມແຖວ"

#: view/kateview.cpp:630
#, kde-format
msgid "Invoke Code Completion"
msgstr "ເອີ້ນໃຊ້ການເຕີມເຕັມໂຄດ"

#: view/kateview.cpp:631
#, kde-format
msgid ""
"Manually invoke command completion, usually by using a shortcut bound to "
"this action."
msgstr "ເອີ້ນໃຊ້ການເຕີມເຕັມຄຳສັ່ງດ້ວຍຕົນເອງ, ໂດຍປົກກະຕິແລ້ວຈະໃຊ້ຄີລັດທີ່ຜູກກັບການກະທຳນີ້."

#: view/kateview.cpp:636
#, kde-format
msgid "Remove Trailing Spaces"
msgstr "ລຶບຍະຫວ່າງທ້າຍແຖວ"

#: view/kateview.cpp:654
#, kde-format
msgid "Print the current document."
msgstr "ພິມເອກະສານປັດຈຸບັນ."

#: view/kateview.cpp:657
#, kde-format
msgid "Show print preview of current document"
msgstr "ສະແດງຕົວຢ່າງການພິມຂອງເອກະສານປັດຈຸບັນ"

#: view/kateview.cpp:661
#, kde-format
msgid "Reloa&d"
msgstr "ໂຫຼດ&ຄືນໃໝ່"

#: view/kateview.cpp:663
#, kde-format
msgid "Reload the current document from disk."
msgstr "ໂຫຼດເອກະສານປັດຈຸບັນຄືນໃໝ່ຈາກດິດ."

#: view/kateview.cpp:667
#, kde-format
msgid "Save the current document to disk, with a name of your choice."
msgstr "ບັນທຶກເອກະສານປັດຈຸບັນລົງດິດ, ດ້ວຍຊື່ທີ່ທ່ານເລືອກ."

#: view/kateview.cpp:669
#, kde-format
msgctxt "@action"
msgid "Save As with Encodin&g…"
msgstr "ບັນທຶກເປັນ ພ້ອມກຳນົດການເຂົ້າລະ&ຫັດ…"

#: view/kateview.cpp:675
#, kde-format
msgctxt "@action"
msgid "Save Cop&y As…"
msgstr "ບັນທຶກສຳເ&ນົາເປັນ…"

#: view/kateview.cpp:676
#, kde-format
msgid "Save a copy of the current document to disk."
msgstr "ບັນທຶກສຳເນົາຂອງເອກະສານປັດຈຸບັນລົງດິດ."

#: view/kateview.cpp:680
#, kde-format
msgid ""
"This command opens a dialog and lets you choose a line that you want the "
"cursor to move to."
msgstr "ຄຳສັ່ງນີ້ເປີດກ່ອງໂຕ້ຕອບ ແລະ ໃຫ້ທ່ານເລືອກແຖວທີ່ທ່ານຕ້ອງການຍ້າຍເຄີເຊີໄປຫາ."

#: view/kateview.cpp:684
#, kde-format
msgid "Go to Previous Modified Line"
msgstr "ໄປຍັງແຖວທີ່ມີການແກ້ໄຂກ່ອນໜ້າ"

#: view/kateview.cpp:685
#, kde-format
msgid "Move upwards to the previous modified line."
msgstr "ຍ້າຍຂຶ້ນເທິງໄປຍັງແຖວທີ່ມີການແກ້ໄຂກ່ອນໜ້າ."

#: view/kateview.cpp:690
#, kde-format
msgid "Go to Next Modified Line"
msgstr "ໄປຍັງແຖວທີ່ມີການແກ້ໄຂຖັດໄປ"

#: view/kateview.cpp:691
#, kde-format
msgid "Move downwards to the next modified line."
msgstr "ຍ້າຍລົງລຸ່ມໄປຍັງແຖວທີ່ມີການແກ້ໄຂຖັດໄປ."

#: view/kateview.cpp:695
#, kde-format
msgctxt "@action"
msgid "&Configure Editor…"
msgstr "&ຕັ້ງຄ່າບັນນາທິການ…"

#: view/kateview.cpp:697
#, kde-format
msgid "Configure various aspects of this editor."
msgstr "ຕັ້ງຄ່າດ້ານຕ່າງໆຂອງບັນນາທິການນີ້."

#: view/kateview.cpp:700
#, kde-format
msgid "&Mode"
msgstr "&ໂໝດ"

#: view/kateview.cpp:706
#, kde-format
msgid "&Highlighting"
msgstr "&ການເນັ້ນສີ"

#: view/kateview.cpp:708
#, kde-format
msgid "Here you can choose how the current document should be highlighted."
msgstr "ຢູ່ນີ້ທ່ານສາມາດເລືອກວິທີການເນັ້ນສີເອກະສານປັດຈຸບັນ."

#: view/kateview.cpp:711
#, kde-format
msgid "&Editor Color Theme"
msgstr "ຮູບແບບສີ&ບັນນາທິການ"

#: view/kateview.cpp:717
#, kde-format
msgid "&Indentation"
msgstr "&ການຫຍໍ້ໜ້າ"

#: view/kateview.cpp:726
#, kde-format
msgid "Select the entire text of the current document."
msgstr "ເລືອກຂໍ້ຄວາມທັງໝົດຂອງເອກະສານປັດຈຸບັນ."

#: view/kateview.cpp:729
#, kde-format
msgid ""
"If you have selected something within the current document, this will no "
"longer be selected."
msgstr "ຖ້າທ່ານໄດ້ເລືອກບາງຢ່າງໃນເອກະສານປັດຈຸບັນ, ມັນຈະບໍ່ຖືກເລືອກອີກຕໍ່ໄປ."

#: view/kateview.cpp:733
#, kde-format
msgid "Enlarge Font"
msgstr "ຂະຫຍາຍຟອນ"

#: view/kateview.cpp:735
#, kde-format
msgid "This increases the display font size."
msgstr "ນີ້ຈະເພີ່ມຂະໜາດຟອນທີ່ສະແດງຜົນ."

#: view/kateview.cpp:742
#, kde-format
msgid "Shrink Font"
msgstr "ຫຍໍ້ຟອນ"

#: view/kateview.cpp:744
#, kde-format
msgid "This decreases the display font size."
msgstr "ນີ້ຈະຫຼຸດຂະໜາດຟອນທີ່ສະແດງຜົນ."

#: view/kateview.cpp:751
#, kde-format
msgid "Reset Font Size"
msgstr "ຣີເຊັດຂະໜາດຟອນ"

#: view/kateview.cpp:753
#, kde-format
msgid "This resets the display font size."
msgstr "ນີ້ຈະຣີເຊັດຂະໜາດຟອນທີ່ສະແດງຜົນ."

#: view/kateview.cpp:756
#, kde-format
msgid "Bl&ock Selection Mode"
msgstr "ໂໝດເລືອກແບບບ&ລັອກ"

#: view/kateview.cpp:759
#, kde-format
msgid ""
"This command allows switching between the normal (line based) selection mode "
"and the block selection mode."
msgstr "ຄຳສັ່ງນີ້ອະນຸຍາດໃຫ້ສະຫຼັບລະຫວ່າງໂໝດການເລືອກປົກກະຕິ (ຕາມແຖວ) ແລະ ໂໝດການເລືອກແບບບລັອກ."

#: view/kateview.cpp:763
#, kde-format
msgid "Switch to Next Input Mode"
msgstr "ສະຫຼັບໄປໂໝດປ້ອນຂໍ້ມູນຖັດໄປ"

#: view/kateview.cpp:765
#, kde-format
msgid "Switch to the next input mode."
msgstr "ສະຫຼັບໄປຍັງໂໝດປ້ອນຂໍ້ມູນຖັດໄປ."

#: view/kateview.cpp:768
#, kde-format
msgid "Overwr&ite Mode"
msgstr "ໂໝດຂຽນ&ທັບ"

#: view/kateview.cpp:771
#, kde-format
msgid ""
"Choose whether you want the text you type to be inserted or to overwrite "
"existing text."
msgstr "ເລືອກວ່າທ່ານຕ້ອງການໃຫ້ຂໍ້ຄວາມທີ່ທ່ານພິມຖືກແຊກ ຫຼື ຂຽນທັບຂໍ້ຄວາມທີ່ມີຢູ່."

#: view/kateview.cpp:775
#, kde-format
msgid "Show Whitespace"
msgstr "ສະແດງຍະຫວ່າງ (Whitespace)"

#: view/kateview.cpp:778
#, kde-format
msgid ""
"If this option is checked, whitespaces in this document will be visible.<br /"
"><br />This is only a view option, meaning the document will not be changed."
msgstr ""
"ຖ້າເລືອກຕົວເລືອກນີ້, ຍະຫວ່າງໃນເອກະສານນີ້ຈະສາມາດເບິ່ງເຫັນໄດ້.<br /><br /"
">ນີ້ເປັນພຽງຕົວເລືອກມຸມມອງ, ໝາຍຄວາມວ່າເອກະສານຈະບໍ່ຖືກປ່ຽນແປງ."

#: view/kateview.cpp:782
#, kde-format
msgid "&Dynamic Word Wrap"
msgstr "ການຕັດຄຳແບບ&ໄດນາມິກ"

#: view/kateview.cpp:786
#, kde-format
msgid ""
"If this option is checked, the text lines will be wrapped at the view border "
"on the screen.<br /><br />This is only a view option, meaning the document "
"will not be changed."
msgstr ""
"ຖ້າເລືອກຕົວເລືອກນີ້, ແຖວຂໍ້ຄວາມຈະຖືກຕັດຢູ່ຂອບມຸມມອງຂອງໜ້າຈໍ.<br /><br />ນີ້ເປັນພຽງຕົວເລືອກມຸມມອງ, "
"ໝາຍຄວາມວ່າເອກະສານຈະບໍ່ຖືກປ່ຽນແປງ."

#: view/kateview.cpp:790
#, kde-format
msgid "Dynamic Word Wrap Indicators"
msgstr "ຕົວຊີ້ບອກການຕັດຄຳແບບໄດນາມິກ"

#: view/kateview.cpp:792
#, kde-format
msgid "Choose when the Dynamic Word Wrap Indicators should be displayed"
msgstr "ເລືອກວ່າຄວນສະແດງຕົວຊີ້ບອກການຕັດຄຳແບບໄດນາມິກເມື່ອໃດ"

#: view/kateview.cpp:794
#, kde-format
msgid "&Off"
msgstr "&ປິດ"

#: view/kateview.cpp:794
#, kde-format
msgid "Follow &Line Numbers"
msgstr "ຕາມ&ເລກແຖວ"

#: view/kateview.cpp:794
#, kde-format
msgid "&Always On"
msgstr "&ເປີດຕະຫຼອດ"

#: view/kateview.cpp:798
#, kde-format
msgid "Static Word Wrap"
msgstr "ການຕັດຄຳແບບຄົງທີ່"

#: view/kateview.cpp:800
#, kde-format
msgid ""
"If this option is checked, the text lines will be wrapped at the column "
"defined in the editing properties."
msgstr "ຖ້າເລືອກຕົວເລືອກນີ້, ແຖວຂໍ້ຄວາມຈະຖືກຕັດຢູ່ຖັນທີ່ກຳນົດໄວ້ໃນຄຸນສົມບັດການແກ້ໄຂ."

#: view/kateview.cpp:807
#, kde-format
msgid "Show Static &Word Wrap Marker"
msgstr "ສະແດງເຄື່ອງໝາຍການຕັດຄຳແບບ&ຄົງທີ່"

#: view/kateview.cpp:810
#, kde-format
msgid ""
"Show/hide the Word Wrap Marker, a vertical line drawn at the word wrap "
"column as defined in the editing properties"
msgstr "ສະແດງ/ເຊື່ອງ ເຄື່ອງໝາຍການຕັດຄຳ, ເສັ້ນຕັ້ງທີ່ແຕ້ມຢູ່ຖັນຕັດຄຳ ຕາມທີ່ກຳນົດໄວ້ໃນຄຸນສົມບັດການແກ້ໄຂ"

#: view/kateview.cpp:814
#, kde-format
msgid "Show Folding &Markers"
msgstr "ສະແດງ&ເຄື່ອງໝາຍການຫຍໍ້"

#: view/kateview.cpp:816
#, kde-format
msgid ""
"You can choose if the codefolding marks should be shown, if codefolding is "
"possible."
msgstr "ທ່ານສາມາດເລືອກວ່າຄວນສະແດງເຄື່ອງໝາຍຫຍໍ້ໂຄດຫຼືບໍ່, ຖ້າການຫຍໍ້ໂຄດສາມາດເຮັດໄດ້."

#: view/kateview.cpp:819
#, kde-format
msgid "Show &Icon Border"
msgstr "ສະແດງ&ຂອບໄອຄອນ"

#: view/kateview.cpp:821
#, kde-format
msgid ""
"Show/hide the icon border.<br /><br />The icon border shows bookmark "
"symbols, for instance."
msgstr "ສະແດງ/ເຊື່ອງ ຂອບໄອຄອນ.<br /><br />ຂອບໄອຄອນສະແດງສັນຍາລັກຂັ້ນໜ້າ, ເປັນຕົ້ນ."

#: view/kateview.cpp:824
#, kde-format
msgid "Show &Line Numbers"
msgstr "ສະແດງ&ເລກແຖວ"

#: view/kateview.cpp:826
#, kde-format
msgid "Show/hide the line numbers on the left hand side of the view."
msgstr "ສະແດງ/ເຊື່ອງ ເລກແຖວ ຢູ່ເບື້ອງຊ້າຍຂອງມຸມມອງ."

#: view/kateview.cpp:829
#, kde-format
msgid "Show Scroll&bar Marks"
msgstr "ສະແດງເຄື່ອງໝາຍໃນແຖບ&ເລື່ອນ"

#: view/kateview.cpp:831
#, kde-format
msgid ""
"Show/hide the marks on the vertical scrollbar.<br /><br />The marks show "
"bookmarks, for instance."
msgstr ""
"ສະແດງ/ເຊື່ອງ ເຄື່ອງໝາຍໃນແຖບເລື່ອນແນວຕັ້ງ.<br /><br />ເຄື່ອງໝາຍສະແດງການຂັ້ນໜ້າ, ເປັນຕົ້ນ."

#: view/kateview.cpp:834
#, kde-format
msgid "Show Scrollbar Mini-Map"
msgstr "ສະແດງແຜນທີ່ຫຍໍ້ໃນແຖບເລື່ອນ"

#: view/kateview.cpp:836
#, kde-format
msgid ""
"Show/hide the mini-map on the vertical scrollbar.<br /><br />The mini-map "
"shows an overview of the whole document."
msgstr ""
"ສະແດງ/ເຊື່ອງ ແຜນທີ່ຫຍໍ້ໃນແຖບເລື່ອນແນວຕັ້ງ.<br /><br />ແຜນທີ່ຫຍໍ້ສະແດງພາບລວມຂອງເອກະສານທັງໝົດ."

#. i18n("Show the whole document in the Mini-Map"), this);
#. ac->addAction(QLatin1String("view_scrollbar_minimap_all"), a);
#. a->setWhatsThis(i18n("Display the whole document in the mini-map.<br /><br />With this option set the whole document will be visible in the
#. mini-map.")); connect(a, SIGNAL(triggered(bool)), SlOT(toggleScrollBarMiniMapAll())); connect(m_toggleScrollBarMiniMap, SIGNAL(triggered(bool)),
#. m_toggleScrollBarMiniMapAll, SLOT(setEnabled(bool)));
#: view/kateview.cpp:848
#, kde-format
msgid "Show Non-Printable Spaces"
