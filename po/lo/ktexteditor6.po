msgid "Auto Reload Document"
msgstr "ໂຫຼດເອກະສານຄືນອັດຕະໂນມັດ"

#: document/katedocument.cpp:225
#, kde-format
msgid "Automatic reload the document when it was changed on disk"
msgstr "ໂຫຼດເອກະສານຄືນອັດຕະໂນມັດເມື່ອມີການປ່ຽນແປງໃນດິດ"

#: document/katedocument.cpp:2307
#, kde-format
msgid ""
"The file %1 could not be loaded, as it was not possible to read from it.<br /"
">Check if you have read access to this file."
msgstr ""
"ບໍ່ສາມາດໂຫຼດແຟ້ມ %1 ໄດ້, ເນື່ອງຈາກບໍ່ສາມາດອ່ານຈາກມັນໄດ້.<br />ກວດສອບວ່າທ່ານມີສິດອ່ານແຟ້ມນີ້."

#: document/katedocument.cpp:2312
#, kde-format
msgctxt "translators: you can also translate 'Try Again' with 'Reload'"
msgid "Try Again"
msgstr "ລອງໃໝ່"

#: document/katedocument.cpp:2316 document/katedocument.cpp:6534
#, kde-format
msgid "&Close"
msgstr "&ປິດ"

#: document/katedocument.cpp:2317 document/katedocument.cpp:6535
#, kde-format
msgctxt "Close the message being displayed"
msgid "Close message"
msgstr "ປິດຂໍ້ຄວາມ"

#: document/katedocument.cpp:2449
#, kde-format
msgid ""
"The file %1 was opened with %2 encoding but contained invalid characters."
"<br />It is set to read-only mode, as saving might destroy its content.<br /"
">Either reopen the file with the correct encoding chosen or enable the read-"
"write mode again in the tools menu to be able to edit it."
msgstr ""
"ແຟ້ມ %1 ຖືກເປີດດ້ວຍການເຂົ້າລະຫັດ %2 ແຕ່ມີຕົວອັກສອນທີ່ບໍ່ຖືກຕ້ອງ.<br />ມັນຖືກຕັ້ງເປັນໂໝດອ່ານຢ່າງດຽວ, "
"ເນື່ອງຈາກການບັນທຶກອາດທຳລາຍເນື້ອໃນຂອງມັນ.<br />ໃຫ້ເປີດແຟ້ມໃໝ່ດ້ວຍການເຂົ້າລະຫັດທີ່ຖືກຕ້ອງ ຫຼື "
"ເປີດໃຊ້ໂໝດອ່ານ-ຂຽນອີກຄັ້ງໃນເມນູເຄື່ອງມືເພື່ອໃຫ້ສາມາດແກ້ໄຂມັນໄດ້."

#: document/katedocument.cpp:2468
#, kde-format
msgid ""
"The file %1 was opened and contained lines longer than the configured Line "
"Length Limit (%2 characters).<br />The longest of those lines was %3 "
"characters long<br/>Those lines were wrapped and the document is set to read-"
"only mode, as saving will modify its content."
msgstr ""
"ແຟ້ມ %1 ຖືກເປີດແລະມີແຖວທີ່ຍາວກວ່າຂີດຈຳກັດຄວາມຍາວແຖວທີ່ກຳນົດໄວ້ (%2 ຕົວອັກສອນ).<br /"
">ແຖວທີ່ຍາວທີ່ສຸດໃນນັ້ນມີຄວາມຍາວ %3 ຕົວອັກສອນ<br/>ແຖວເຫຼົ່ານັ້ນຖືກຕັດ "
"ແລະເອກະສານຖືກຕັ້ງເປັນໂໝດອ່ານຢ່າງດຽວ, ເນື່ອງຈາກການບັນທຶກຈະແກ້ໄຂເນື້ອໃນຂອງມັນ."

