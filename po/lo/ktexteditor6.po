msgstr "ຄຸນສົມບັດ"

#. i18n: ectx: property (text), widget (QLabel, lblName)
#: dialogs/filetypeconfigwidget.ui:72
#, kde-format
msgid "&Name:"
msgstr "&ຊື່:"

#. i18n: ectx: property (whatsThis), widget (QLineEdit, edtName)
#: dialogs/filetypeconfigwidget.ui:82
#, kde-format
