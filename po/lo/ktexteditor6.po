#, kde-format
msgid "Document written to disk"
msgstr "ເອກະສານຖືກຂຽນລົງດິດແລ້ວ"

#: vimode/appcommands.cpp:202
#, kde-format
msgid ""
"<p><b>w/wa &mdash; write document(s) to disk</b></p><p>Usage: <tt><b>w[a]</"
"b></tt></p><p>Writes the current document(s) to disk. It can be called in "
"two ways:<br /> <tt>w</tt> &mdash; writes the current document to disk<br /> "
"<tt>wa</tt> &mdash; writes all documents to disk.</p><p>If no file name is "
"associated with the document, a file dialog will be shown.</p>"
msgstr ""
"<p><b>w/wa &mdash; ຂຽນເອກະສານລົງດິດ</b></p><p>ວິທີໃຊ້: <tt><b>w[a]</b></tt></"
"p><p>ຂຽນເອກະສານປັດຈຸບັນລົງດິດ. ສາມາດເອີ້ນໃຊ້ໄດ້ສອງວິທີ:<br /> <tt>w</tt> &mdash; "
"ຂຽນເອກະສານປັດຈຸບັນລົງດິດ<br /> <tt>wa</tt> &mdash; ຂຽນເອກະສານທັງໝົດລົງດິດ.</"
"p><p>ຖ້າບໍ່ມີຊື່ໄຟລ໌ກ່ຽວຂ້ອງກັບເອກະສານ, ກ່ອງໂຕ້ຕອບໄຟລ໌ຈະຖືກສະແດງ.</p>"

#: vimode/appcommands.cpp:213
#, kde-format
msgid ""
"<p><b>q/qa/wq/wqa &mdash; [write and] quit</b></p><p>Usage: <tt><b>[w]q[a]</"
"b></tt></p><p>Quits the application. If <tt>w</tt> is prepended, it also "
"writes the document(s) to disk. This command can be called in several ways:"
"<br /> <tt>q</tt> &mdash; closes the current view.<br /> <tt>qa</tt> &mdash; "
"closes all views, effectively quitting the application.<br /> <tt>wq</tt> "
"&mdash; writes the current document to disk and closes its view.<br /> "
"<tt>wqa</tt> &mdash; writes all documents to disk and quits.</p><p>In all "
"cases, if the view being closed is the last view, the application quits. If "
"no file name is associated with the document and it should be written to "
"disk, a file dialog will be shown.</p>"
msgstr ""
"<p><b>q/qa/wq/wqa &mdash; [ຂຽນ ແລະ] ອອກ</b></p><p>ວິທີໃຊ້: <tt><b>[w]q[a]</b></"
"tt></p><p>ອອກຈາກແອັບພລິເຄຊັນ. ຖ້າໃສ່ <tt>w</tt> ທາງໜ້າ, ມັນຈະຂຽນເອກະສານລົງດິດນຳ. "
"ຄຳສັ່ງນີ້ສາມາດເອີ້ນໃຊ້ໄດ້ຫຼາຍວິທີ:<br /> <tt>q</tt> &mdash; ປິດມຸມມອງປັດຈຸບັນ.<br /> <tt>qa</"
"tt> &mdash; ປິດມຸມມອງທັງໝົດ, ເຊິ່ງເປັນການອອກຈາກແອັບພລິເຄຊັນ.<br /> <tt>wq</tt> &mdash; "
"ຂຽນເອກະສານປັດຈຸບັນລົງດິດ ແລະ ປິດມຸມມອງຂອງມັນ.<br /> <tt>wqa</tt> &mdash; "
"ຂຽນເອກະສານທັງໝົດລົງດິດ ແລະ ອອກ.</p><p>ໃນທຸກກໍລະນີ, ຖ້າມຸມມອງທີ່ກຳລັງປິດເປັນມຸມມອງສຸດທ້າຍ, "
"ແອັບພລິເຄຊັນຈະອອກ. ຖ້າບໍ່ມີຊື່ໄຟລ໌ກ່ຽວຂ້ອງກັບເອກະສານ ແລະ ມັນຄວນຈະຖືກຂຽນລົງດິດ, "
"ກ່ອງໂຕ້ຕອບໄຟລ໌ຈະຖືກສະແດງ.</p>"

#: vimode/appcommands.cpp:228
#, kde-format
msgid ""
"<p><b>x/xa &mdash; write and quit</b></p><p>Usage: <tt><b>x[a]</b></tt></"
"p><p>Saves document(s) and quits (e<b>x</b>its). This command can be called "
"in two ways:<br /> <tt>x</tt> &mdash; closes the current view.<br /> <tt>xa</"
"tt> &mdash; closes all views, effectively quitting the application.</p><p>In "
"all cases, if the view being closed is the last view, the application quits. "
"If no file name is associated with the document and it should be written to "
"disk, a file dialog will be shown.</p><p>Unlike the 'w' commands, this "
"command only writes the document if it is modified.</p>"
msgstr ""
"<p><b>x/xa &mdash; ຂຽນ ແລະ ອອກ</b></p><p>ວິທີໃຊ້: <tt><b>x[a]</b></tt></"
"p><p>ບັນທຶກເອກະສານ ແລະ ອອກ (e<b>x</b>its). ຄຳສັ່ງນີ້ສາມາດເອີ້ນໃຊ້ໄດ້ສອງວິທີ:<br /> "
"<tt>x</tt> &mdash; ປິດມຸມມອງປັດຈຸບັນ.<br /> <tt>xa</tt> &mdash; ປິດມຸມມອງທັງໝົດ, "
"ເຊິ່ງເປັນການອອກຈາກແອັບພລິເຄຊັນ.</p><p>ໃນທຸກກໍລະນີ, ຖ້າມຸມມອງທີ່ກຳລັງປິດເປັນມຸມມອງສຸດທ້າຍ, "
"ແອັບພລິເຄຊັນຈະອອກ. ຖ້າບໍ່ມີຊື່ໄຟລ໌ກ່ຽວຂ້ອງກັບເອກະສານ ແລະ ມັນຄວນຈະຖືກຂຽນລົງດິດ, "
"ກ່ອງໂຕ້ຕອບໄຟລ໌ຈະຖືກສະແດງ.</p><p>ຕ່າງຈາກຄຳສັ່ງ 'w', "
"ຄຳສັ່ງນີ້ຈະຂຽນເອກະສານສະເພາະກໍລະນີທີ່ມີການແກ້ໄຂເທົ່ານັ້ນ.</p>"

#: vimode/appcommands.cpp:242
#, kde-format
msgid ""
"<p><b>sp,split&mdash; Split horizontally the current view into two</b></"
"p><p>Usage: <tt><b>sp[lit]</b></tt></p><p>The result is two views on the "
"same document.</p>"
msgstr ""
"<p><b>sp,split&mdash; ແຍກມຸມມອງປັດຈຸບັນຕາມແນວນອນເປັນສອງສ່ວນ</b></p><p>ວິທີໃຊ້: "
"<tt><b>sp[lit]</b></tt></p><p>ຜົນທີ່ໄດ້ແມ່ນສອງມຸມມອງໃນເອກະສານດຽວກັນ.</p>"

#: vimode/appcommands.cpp:248
#, kde-format
msgid ""
"<p><b>vs,vsplit&mdash; Split vertically the current view into two</b></"
"p><p>Usage: <tt><b>vs[plit]</b></tt></p><p>The result is two views on the "
"same document.</p>"
msgstr ""
"<p><b>vs,vsplit&mdash; ແຍກມຸມມອງປັດຈຸບັນຕາມແນວຕັ້ງເປັນສອງສ່ວນ</b></p><p>ວິທີໃຊ້: "
"<tt><b>vs[plit]</b></tt></p><p>ຜົນທີ່ໄດ້ແມ່ນສອງມຸມມອງໃນເອກະສານດຽວກັນ.</p>"

#: vimode/appcommands.cpp:254
#, kde-format
msgid ""
"<p><b>clo[se]&mdash; Close the current view</b></p><p>Usage: <tt><b>clo[se]</"
"b></tt></p><p>After executing it, the current view will be closed.</p>"
msgstr ""
"<p><b>clo[se]&mdash; ປິດມຸມມອງປັດຈຸບັນ</b></p><p>ວິທີໃຊ້: <tt><b>clo[se]</b></tt></"
"p><p>ຫຼັງຈາກປະຕິບັດ, ມຸມມອງປັດຈຸບັນຈະຖືກປິດ.</p>"

#: vimode/appcommands.cpp:260
#, kde-format
msgid ""
"<p><b>[v]new &mdash; split view and create new document</b></p><p>Usage: "
"<tt><b>[v]new</b></tt></p><p>Splits the current view and opens a new "
"document in the new view. This command can be called in two ways:<br /> "
"<tt>new</tt> &mdash; splits the view horizontally and opens a new document."
"<br /> <tt>vnew</tt> &mdash; splits the view vertically and opens a new "
"document.<br /></p>"
msgstr ""
"<p><b>[v]new &mdash; ແຍກມຸມມອງ ແລະ ສ້າງເອກະສານໃໝ່</b></p><p>ວິທີໃຊ້: "
"<tt><b>[v]new</b></tt></p><p>ແຍກມຸມມອງປັດຈຸບັນ ແລະ ເປີດເອກະສານໃໝ່ໃນມຸມມອງໃໝ່. "
"ຄຳສັ່ງນີ້ສາມາດເອີ້ນໃຊ້ໄດ້ສອງວິທີ:<br /> <tt>new</tt> &mdash; ແຍກມຸມມອງຕາມແນວນອນ ແລະ "
"ເປີດເອກະສານໃໝ່.<br /> <tt>vnew</tt> &mdash; ແຍກມຸມມອງຕາມແນວຕັ້ງ ແລະ ເປີດເອກະສານໃໝ່."
"<br /></p>"

#: vimode/appcommands.cpp:270
#, kde-format
msgid ""
"<p><b>e[dit] &mdash; reload current document</b></p><p>Usage: <tt><b>e[dit]</"
"b></tt></p><p>Starts <b>e</b>diting the current document again. This is "
"useful to re-edit the current file, when it was modified on disk.</p>"
msgstr ""
"<p><b>e[dit] &mdash; ໂຫຼດເອກະສານປັດຈຸບັນຄືນໃໝ່</b></p><p>ວິທີໃຊ້: <tt><b>e[dit]</b></"
"tt></p><p>ເລີ່ມ <b>e</b>diting ເອກະສານປັດຈຸບັນອີກຄັ້ງ. "
"ສິ່ງນີ້ມີປະໂຫຍດໃນການແກ້ໄຂໄຟລ໌ປັດຈຸບັນຄືນໃໝ່, ເມື່ອມັນຖືກແກ້ໄຂໃນດິດ.</p>"

#: vimode/appcommands.cpp:518
#, kde-format
msgid ""
"<p><b>b,buffer &mdash; Edit document N from the document list</b></"
"p><p>Usage: <tt><b>b[uffer] [N]</b></tt></p>"
msgstr ""
"<p><b>b,buffer &mdash; ແກ້ໄຂເອກະສານ N ຈາກລາຍການເອກະສານ</b></p><p>ວິທີໃຊ້: "
"<tt><b>b[uffer] [N]</b></tt></p>"

#: vimode/appcommands.cpp:523
#, kde-format
msgid ""
"<p><b>bp,bprev &mdash; previous buffer</b></p><p>Usage: <tt><b>bp[revious] "
"[N]</b></tt></p><p>Goes to <b>[N]</b>th previous document (\"<b>b</b>uffer"
"\") in document list. </p><p> <b>[N]</b> defaults to one. </p><p>Wraps "
"around the start of the document list.</p>"
msgstr ""
"<p><b>bp,bprev &mdash; buffer ກ່ອນໜ້າ</b></p><p>ວິທີໃຊ້: <tt><b>bp[revious] [N]</"
"b></tt></p><p>ໄປຍັງເອກະສານກ່ອນໜ້າລຳດັບທີ <b>[N]</b> (\"<b>b</b>uffer\") "
"ໃນລາຍການເອກະສານ. </p><p> <b>[N]</b> ເລີ່ມຕົ້ນແມ່ນໜຶ່ງ. </"
"p><p>ວົນກັບໄປຫາຈຸດເລີ່ມຕົ້ນຂອງລາຍການເອກະສານ.</p>"

#: vimode/appcommands.cpp:531
#, kde-format
msgid ""
"<p><b>bn,bnext &mdash; switch to next document</b></p><p>Usage: "
"<tt><b>bn[ext] [N]</b></tt></p><p>Goes to <b>[N]</b>th next document "
"(\"<b>b</b>uffer\") in document list.<b>[N]</b> defaults to one. </"
"p><p>Wraps around the end of the document list.</p>"
msgstr ""
"<p><b>bn,bnext &mdash; ສະຫຼັບໄປເອກະສານຖັດໄປ</b></p><p>ວິທີໃຊ້: <tt><b>bn[ext] [N]</"
"b></tt></p><p>ໄປຍັງເອກະສານຖັດໄປລຳດັບທີ <b>[N]</b> (\"<b>b</b>uffer\") "
"ໃນລາຍການເອກະສານ.<b>[N]</b> ເລີ່ມຕົ້ນແມ່ນໜຶ່ງ. </p><p>ວົນກັບໄປຫາຈຸດສິ້ນສຸດຂອງລາຍການເອກະສານ."
"</p>"

#: vimode/appcommands.cpp:539
#, kde-format
msgid ""
"<p><b>bf,bfirst &mdash; first document</b></p><p>Usage: <tt><b>bf[irst]</b></"
"tt></p><p>Goes to the <b>f</b>irst document (\"<b>b</b>uffer\") in document "
"list.</p>"
msgstr ""
"<p><b>bf,bfirst &mdash; ເອກະສານທຳອິດ</b></p><p>ວິທີໃຊ້: <tt><b>bf[irst]</b></"
"tt></p><p>ໄປຍັງເອກະສານ <b>f</b>irst (\"<b>b</b>uffer\") ໃນລາຍການເອກະສານ.</p>"

#: vimode/appcommands.cpp:545
#, kde-format
msgid ""
"<p><b>bl,blast &mdash; last document</b></p><p>Usage: <tt><b>bl[ast]</b></"
"tt></p><p>Goes to the <b>l</b>ast document (\"<b>b</b>uffer\") in document "
"list.</p>"
msgstr ""
"<p><b>bl,blast &mdash; ເອກະສານສຸດທ້າຍ</b></p><p>ວິທີໃຊ້: <tt><b>bl[ast]</b></tt></"
"p><p>ໄປຍັງເອກະສານ <b>l</b>ast (\"<b>b</b>uffer\") ໃນລາຍການເອກະສານ.</p>"

#: vimode/appcommands.cpp:551
#, kde-format
msgid "<p><b>ls</b></p><p>list current buffers<p>"
msgstr "<p><b>ls</b></p><p>ລາຍການ buffer ປັດຈຸບັນ<p>"

