msgid "<p>Format of the page header. The following tags are supported:</p>"
msgstr "<p>ຮູບແບບຂອງຫົວກະດາດ. ແທັກຕໍ່ໄປນີ້ຖືກຮອງຮັບ:</p>"

#: printing/printconfigwidgets.cpp:252
#, kde-format
msgid ""
"<ul><li><tt>%u</tt>: current user name</li><li><tt>%d</tt>: complete date/"
"time in short format</li><li><tt>%D</tt>: complete date/time in long format</"
"li><li><tt>%h</tt>: current time</li><li><tt>%y</tt>: current date in short "
"format</li><li><tt>%Y</tt>: current date in long format</li><li><tt>%f</tt>: "
"file name</li><li><tt>%U</tt>: full URL of the document</li><li><tt>%p</tt>: "
"page number</li><li><tt>%P</tt>: total amount of pages</li></ul><br />"
msgstr ""
"<ul><li><tt>%u</tt>: ຊື່ຜູ້ໃຊ້ປັດຈຸບັນ</li><li><tt>%d</tt>: ວັນທີ/ເວລາ ເຕັມ ໃນຮູບແບບສັ້ນ</"
"li><li><tt>%D</tt>: ວັນທີ/ເວລາ ເຕັມ ໃນຮູບແບບຍາວ</li><li><tt>%h</tt>: ເວລາປັດຈຸບັນ</"
"li><li><tt>%y</tt>: ວັນທີປັດຈຸບັນ ໃນຮູບແບບສັ້ນ</li><li><tt>%Y</tt>: ວັນທີປັດຈຸບັນ "
"ໃນຮູບແບບຍາວ</li><li><tt>%f</tt>: ຊື່ແຟ້ມ</li><li><tt>%U</tt>: URL ເຕັມຂອງເອກະສານ</"
"li><li><tt>%p</tt>: ເລກໜ້າ</li><li><tt>%P</tt>: ຈຳນວນໜ້າທັງໝົດ</li></ul><br />"

