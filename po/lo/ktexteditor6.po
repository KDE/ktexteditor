#: view/kateview.cpp:477
#, kde-format
msgid "Take Screenshot of Selection"
msgstr "ຖ່າຍຮູບໜ້າຈໍສ່ວນທີ່ເລືອກ"

#: view/kateview.cpp:481
#, kde-format
