#: utils/katecmds.cpp:53
#, kde-format
msgid "<p>indent</p><p>Indents the selected lines or the current line</p>"
msgstr "<p>indent</p><p>ຫຍໍ້ໜ້າແຖວທີ່ເລືອກ ຫຼື ແຖວປັດຈຸບັນເຂົ້າ</p>"

#: utils/katecmds.cpp:58
#, kde-format
msgid "<p>unindent</p><p>Unindents the selected lines or current line.</p>"
msgstr "<p>unindent</p><p>ຫຍໍ້ໜ້າແຖວທີ່ເລືອກ ຫຼື ແຖວປັດຈຸບັນອອກ.</p>"

#: utils/katecmds.cpp:63
#, kde-format
msgid ""
"<p>cleanindent</p><p>Cleans up the indentation of the selected lines or "
"current line according to the indentation settings in the document. </p>"
msgstr ""
"<p>cleanindent</p><p>ລ້າງການຫຍໍ້ໜ້າຂອງແຖວທີ່ເລືອກ ຫຼື ແຖວປັດຈຸບັນ "
"ຕາມການຕັ້ງຄ່າການຫຍໍ້ໜ້າໃນເອກະສານ. </p>"

#: utils/katecmds.cpp:68
#, kde-format
msgid ""
"<p>comment</p><p>Inserts comment markers to make the selection or selected "
"lines or current line a comment according to the text format as defined by "
"the syntax highlight definition for the document.</p>"
msgstr ""
"<p>comment</p><p>ແຊກເຄື່ອງໝາຍໝາຍເຫດ ເພື່ອເຮັດໃຫ້ສ່ວນທີ່ເລືອກ ຫຼື ແຖວທີ່ເລືອກ ຫຼື ແຖວປັດຈຸບັນ "
"ກາຍເປັນໝາຍເຫດ ຕາມຮູບແບບຂໍ້ຄວາມທີ່ກຳນົດໄວ້ໂດຍນິຍາມການເນັ້ນສີໄວຍາກອນສຳລັບເອກະສານ.</p>"

#: utils/katecmds.cpp:74
#, kde-format
msgid ""
"<p>uncomment</p><p>Removes comment markers from the selection or selected "
"lines or current line according to the text format as defined by the syntax "
"highlight definition for the document.</p>"
msgstr ""
"<p>uncomment</p><p>ເອົາເຄື່ອງໝາຍໝາຍເຫດອອກຈາກສ່ວນທີ່ເລືອກ ຫຼື ແຖວທີ່ເລືອກ ຫຼື ແຖວປັດຈຸບັນ "
"ຕາມຮູບແບບຂໍ້ຄວາມທີ່ກຳນົດໄວ້ໂດຍນິຍາມການເນັ້ນສີໄວຍາກອນສຳລັບເອກະສານ.</p>"

#: utils/katecmds.cpp:80
#, kde-format
msgid ""
"<p>goto <b>line number</b></p><p>This command navigates to the specified "
"line number.</p>"
msgstr "<p>goto <b>ເລກແຖວ</b></p><p>ຄຳສັ່ງນີ້ຈະພາໄປຍັງເລກແຖວທີ່ລະບຸ.</p>"

#: utils/katecmds.cpp:85
#, kde-format
msgid ""
"<p>set-indent-pasted-text <b>enable</b></p><p>If enabled, indentation of "
"text pasted from the clipboard is adjusted using the current indenter.</"
"p><p>Possible true values: 1 on true<br/>possible false values: 0 off false</"
"p>"
msgstr ""
"<p>set-indent-pasted-text <b>enable</b></p><p>ຖ້າເປີດໃຊ້ງານ, "
"ການຫຍໍ້ໜ້າຂອງຂໍ້ຄວາມທີ່ວາງຈາກຄລິບບອດຈະຖືກປັບ ໂດຍໃຊ້ຕົວຈັດການຫຍໍ້ໜ້າປັດຈຸບັນ.</p><p>ຄ່າທີ່ເປັນຈິງ: 1 "
"on true<br/>ຄ່າທີ່ເປັນເທັດ: 0 off false</p>"

#: utils/katecmds.cpp:91
#, kde-format
msgid "Deletes the current line."
msgstr "ລຶບແຖວປັດຈຸບັນ."

#: utils/katecmds.cpp:95
#, kde-format
msgid ""
"<p>set-tab-width <b>width</b></p><p>Sets the tab width to the number "
"<b>width</b></p>"
msgstr ""
"<p>set-tab-width <b>width</b></p><p>ຕັ້ງຄ່າຄວາມກວ້າງຂອງແຖບ (Tab) ເປັນຈຳນວນ "
"<b>width</b></p>"

#: utils/katecmds.cpp:100
#, kde-format
msgid ""
"<p>set-replace-tab <b>enable</b></p><p>If enabled, tabs are replaced with "
"spaces as you type.</p><p>Possible true values: 1 on true<br/>possible false "
"values: 0 off false</p>"
msgstr ""
"<p>set-replace-tab <b>enable</b></p><p>ຖ້າເປີດໃຊ້ງານ, ແຖບ (Tab) "
"ຈະຖືກແທນທີ່ດ້ວຍຍະຫວ່າງໃນຂະນະທີ່ທ່ານພິມ.</p><p>ຄ່າທີ່ເປັນຈິງ: 1 on true<br/>ຄ່າທີ່ເປັນເທັດ: 0 "
"off false</p>"

#: utils/katecmds.cpp:107
#, kde-format
msgid ""
"<p>set-show-tabs <b>enable</b></p><p>If enabled, TAB characters and trailing "
"whitespace will be visualized by a small dot.</p><p>Possible true values: 1 "
"on true<br/>possible false values: 0 off false</p>"
msgstr ""
"<p>set-show-tabs <b>enable</b></p><p>ຖ້າເປີດໃຊ້ງານ, ຕົວອັກສອນ TAB ແລະ "
"ຍະຫວ່າງທ້າຍແຖວ ຈະຖືກສະແດງດ້ວຍຈຸດນ້ອຍໆ.</p><p>ຄ່າທີ່ເປັນຈິງ: 1 on true<br/>ຄ່າທີ່ເປັນເທັດ: 0 "
"off false</p>"

#: utils/katecmds.cpp:114
#, kde-format
msgid ""
"<p>set-remove-trailing-spaces <b>mode</b></p><p>Removes the trailing spaces "
"in the document depending on the <b>mode</b>.</p><p>Possible values:"
"<ul><li><b>none</b>: never remove trailing spaces.</li><li><b>modified</b>: "
"remove trailing spaces only of modified lines.</li><li><b>all</b>: remove "
"trailing spaces in the entire document.</li></ul></p>"
msgstr ""
"<p>set-remove-trailing-spaces <b>mode</b></p><p>ລຶບຍະຫວ່າງທ້າຍແຖວໃນເອກະສານ ຂຶ້ນກັບ "
"<b>ໂໝດ</b>.</p><p>ຄ່າທີ່ເປັນໄປໄດ້:<ul><li><b>none</b>: ບໍ່ລຶບຍະຫວ່າງທ້າຍແຖວເລີຍ.</"
"li><li><b>modified</b>: ລຶບຍະຫວ່າງທ້າຍແຖວສະເພາະແຖວທີ່ມີການແກ້ໄຂ.</li><li><b>all</"
"b>: ລຶບຍະຫວ່າງທ້າຍແຖວໃນເອກະສານທັງໝົດ.</li></ul></p>"

#: utils/katecmds.cpp:125
#, kde-format
msgid ""
"<p>set-indent-width <b>width</b></p><p>Sets the indentation width to the "
"number <b>width</b>. Used only if you are indenting with spaces.</p>"
msgstr ""
"<p>set-indent-width <b>width</b></p><p>ຕັ້ງຄ່າຄວາມກວ້າງຂອງການຫຍໍ້ໜ້າເປັນຈຳນວນ "
"<b>width</b>. ໃຊ້ສະເພາະກໍລະນີທີ່ທ່ານຫຍໍ້ໜ້າດ້ວຍຍະຫວ່າງ.</p>"

#: utils/katecmds.cpp:130
#, kde-format
msgid ""
"<p>set-indent-mode <b>mode</b></p><p>The mode parameter is a value as seen "
"in the Tools - Indentation menu</p>"
msgstr ""
"<p>set-indent-mode <b>mode</b></p><p>ພາຣາມິເຕີ mode ແມ່ນຄ່າຕາມທີ່ເຫັນໃນ ເມນູ ເຄື່ອງມື - "
"ການຫຍໍ້ໜ້າ</p>"

#: utils/katecmds.cpp:135
#, kde-format
msgid ""
"<p>set-auto-indent <b>enable</b></p><p>Enable or disable autoindentation.</"
"p><p>possible true values: 1 on true<br/>possible false values: 0 off false</"
"p>"
msgstr ""
"<p>set-auto-indent <b>enable</b></p><p>ເປີດ ຫຼື ປິດ ການຫຍໍ້ໜ້າອັດຕະໂນມັດ.</"
"p><p>ຄ່າທີ່ເປັນຈິງ: 1 on true<br/>ຄ່າທີ່ເປັນເທັດ: 0 off false</p>"

#: utils/katecmds.cpp:142
#, kde-format
msgid ""
"<p>set-line-numbers <b>enable</b></p><p>Sets the visibility of the line "
"numbers pane.</p><p> possible true values: 1 on true<br/>possible false "
"values: 0 off false</p>"
msgstr ""
"<p>set-line-numbers <b>enable</b></p><p>ຕັ້ງຄ່າການສະແດງຜົນຂອງແຖບເລກແຖວ.</p><p> "
"ຄ່າທີ່ເປັນຈິງ: 1 on true<br/>ຄ່າທີ່ເປັນເທັດ: 0 off false</p>"

#: utils/katecmds.cpp:149
#, kde-format
msgid ""
"<p>set-folding-markers <b>enable</b></p><p>Sets the visibility of the "
"folding markers pane.</p><p> possible true values: 1 on true<br/>possible "
"false values: 0 off false</p>"
msgstr ""
"<p>set-folding-markers <b>enable</b></p><p>ຕັ້ງຄ່າການສະແດງຜົນຂອງແຖບເຄື່ອງໝາຍການຫຍໍ້."
"</p><p> ຄ່າທີ່ເປັນຈິງ: 1 on true<br/>ຄ່າທີ່ເປັນເທັດ: 0 off false</p>"

#: utils/katecmds.cpp:156
#, kde-format
msgid ""
"<p>set-icon-border <b>enable</b></p><p>Sets the visibility of the icon "
"border.</p><p> possible true values: 1 on true<br/>possible false values: 0 "
"off false</p>"
msgstr ""
"<p>set-icon-border <b>enable</b></p><p>ຕັ້ງຄ່າການສະແດງຜົນຂອງຂອບໄອຄອນ.</p><p> "
"ຄ່າທີ່ເປັນຈິງ: 1 on true<br/>ຄ່າທີ່ເປັນເທັດ: 0 off false</p>"

#: utils/katecmds.cpp:163
#, kde-format
msgid ""
"<p>set-word-wrap <b>enable</b></p><p>Enables dynamic word wrap according to "
"<b>enable</b></p><p> possible true values: 1 on true<br/>possible false "
"values: 0 off false</p>"
msgstr ""
"<p>set-word-wrap <b>enable</b></p><p>ເປີດໃຊ້ງານການຕັດຄຳແບບໄດນາມິກ ຕາມຄ່າ "
"<b>enable</b></p><p> ຄ່າທີ່ເປັນຈິງ: 1 on true<br/>ຄ່າທີ່ເປັນເທັດ: 0 off false</p>"

#: utils/katecmds.cpp:170
#, kde-format
msgid ""
"<p>set-word-wrap-column <b>width</b></p><p>Sets the line width for hard "
"wrapping to <b>width</b>. This is used if you are having your text wrapped "
"automatically.</p>"
msgstr ""
"<p>set-word-wrap-column <b>width</b></"
"p><p>ຕັ້ງຄ່າຄວາມກວ້າງຂອງແຖວສຳລັບການຕັດຄຳແບບແຂງ (Hard Wrap) ເປັນ <b>width</b>. "
"ສິ່ງນີ້ໃຊ້ໃນກໍລະນີທີ່ທ່ານຕ້ອງການໃຫ້ຂໍ້ຄວາມຖືກຕັດໂດຍອັດຕະໂນມັດ.</p>"

#: utils/katecmds.cpp:175
#, kde-format
msgid ""
"<p>set-replace-tabs-save <b>enable</b></p><p>When enabled, tabs will be "
"replaced with whitespace whenever the document is saved.</p><p> possible "
"true values: 1 on true<br/>possible false values: 0 off false</p>"
msgstr ""
"<p>set-replace-tabs-save <b>enable</b></p><p>ເມື່ອເປີດໃຊ້ງານ, ແຖບ (Tab) "
"ຈະຖືກແທນທີ່ດ້ວຍຍະຫວ່າງ ເມື່ອໃດກໍຕາມທີ່ເອກະສານຖືກບັນທຶກ.</p><p> ຄ່າທີ່ເປັນຈິງ: 1 on true<br/"
">ຄ່າທີ່ເປັນເທັດ: 0 off false</p>"

#: utils/katecmds.cpp:182
#, kde-format
msgid ""
"<p>set-highlight <b>highlight</b></p><p>Sets the syntax highlighting system "
"for the document. The argument must be a valid highlight name, as seen in "
"the Tools → Highlighting menu. This command provides an autocompletion list "
"for its argument.</p>"
msgstr ""
"<p>set-highlight <b>highlight</b></p><p>ຕັ້ງຄ່າລະບົບການເນັ້ນສີໄວຍາກອນສຳລັບເອກະສານ. "
"ອາກິວເມັນຕ້ອງເປັນຊື່ການເນັ້ນສີທີ່ຖືກຕ້ອງ, ຕາມທີ່ເຫັນໃນເມນູ ເຄື່ອງມື → ການເນັ້ນສີ. "
"ຄຳສັ່ງນີ້ມີລາຍການເຕີມເຕັມຄຳອັດຕະໂນມັດສຳລັບອາກິວເມັນຂອງມັນ.</p>"

#: utils/katecmds.cpp:188
#, kde-format
msgid "<p>set-mode <b>mode</b></p><p>Sets the mode as seen in Tools - Mode</p>"
msgstr "<p>set-mode <b>mode</b></p><p>ຕັ້ງຄ່າໂໝດຕາມທີ່ເຫັນໃນ ເຄື່ອງມື - ໂໝດ</p>"

#: utils/katecmds.cpp:193
#, kde-format
msgid ""
"<p>set-show-indent <b>enable</b></p><p>If enabled, indentation will be "
"visualized by a vertical dotted line.</p><p> possible true values: 1 on "
"true<br/>possible false values: 0 off false</p>"
msgstr ""
"<p>set-show-indent <b>enable</b></p><p>ຖ້າເປີດໃຊ້ງານ, "
"ການຫຍໍ້ໜ້າຈະຖືກສະແດງໃຫ້ເຫັນດ້ວຍເສັ້ນຈຸດແນວຕັ້ງ.</p><p> ຄ່າທີ່ເປັນຈິງ: 1 on true<br/"
">ຄ່າທີ່ເປັນເທັດ: 0 off false</p>"

#: utils/katecmds.cpp:199
#, kde-format
msgid "<p>Open the Print dialog to print the current document.</p>"
msgstr "<p>ເປີດກ່ອງໂຕ້ຕອບການພິມ ເພື່ອພິມເອກະສານປັດຈຸບັນ.</p>"

